{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ayron_crm staging",
            "request": "launch",
            "type": "dart",
            "program": "${workspaceFolder}/lib/main_staging.dart",
        },
        {
            "name": "ayron_crm dev",
            "request": "launch",
            "type": "dart",
            "program": "${workspaceFolder}/lib/main_development.dart",
            //"preLaunchTask": "adb reverse",
        },
        {
            "name": "ayron_crm web dev",
            "request": "launch",
            "type": "dart",
            "args": ["-d", "chrome","--web-port", "22433", "--web-browser-flag=--disable-web-security"],
        },
        {
            "name": "ayron_crm local",
            "request": "launch",
            "type": "dart",
            "program": "${workspaceFolder}/lib/main_local.dart"
        },
        {
            "name": "ayron_crm (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "ayron_crm (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}